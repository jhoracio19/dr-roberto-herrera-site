{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.otorrinotlaxcala.com" }],
      "destination": "https://otorrinotlaxcala.com/:path*",
      "permanent": true
    },
    {
      "source": "/cirugias.php",
      "destination": "/cirugias",
      "permanent": true
    },
    {
      "source": "/src/img/cv.pdf",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index.php",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/enfermedades.php",
      "destination": "/enfermedades",
      "permanent": true
    },
    {
      "source": "/estetico.php",
      "destination": "/cirugias",
      "permanent": true
    },
    {
      "source": "/pacientes.php",
      "destination": "/",
      "permanent": true
    }
  ]
}
